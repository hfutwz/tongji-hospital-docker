<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.demo.mapper.PatientInjuryDetailMapper">

    <!--
        patient_injury_details / injury_types 表在当前数据库中不存在。
        伤情详情通过 iss_patient_injury_severity 表（IssInjury 实体）提供，
        此查询返回空结果集，不影响主要功能。
    -->
    <select id="selectInjuryDetailsByPatientIdAndBodyPart" resultType="com.demo.dto.InjuryDetailDTO">
        SELECT
            NULL AS injuryTypeId,
            NULL AS injuryName,
            NULL AS injuryDescription,
            NULL AS scoreValue,
            NULL AS injuryCount,
            NULL AS notes
        FROM (SELECT 1) dummy
        WHERE 1 = 0
    </select>

</mapper>
